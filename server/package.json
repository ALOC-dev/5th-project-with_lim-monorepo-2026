{
  "name": "@monorepo/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --sourcemap --external:express",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --env-file-if-exists=.env --import tsx src/recommendation-engine/v1/scripts/test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/openai": "^3.0.64",
    "@monorepo/common": "workspace:*",
    "ai": "^6.0.183",
    "express": "^4.21.2",
    "ky": "^2.0.2",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.17",
    "esbuild": "^0.27.7",
    "tsx": "^4.19.3"
  }
}
