{
  "name": "monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm --filter @monorepo/client build && pnpm --filter @monorepo/server build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @monorepo/server test",
    "clean": "pnpm -r clean",
    "tokens:generate": "node scripts/generate-design-tokens.mjs"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "ky": "^2.0.2",
    "zod": "^4.4.1"
  }
}
