{
  "name": "monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "license": "MIT",
  "engines": {
    "node": ">=22 <26",
    "pnpm": "10.32.1"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm --filter @monorepo/client build && pnpm --filter @monorepo/server build",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @monorepo/server test",
    "clean": "pnpm -r clean",
    "tokens:source": "node scripts/build-token-source.mjs",
    "tokens:generate": "node scripts/generate-design-tokens.mjs",
    "tokens:update": "pnpm tokens:source && pnpm tokens:generate"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.4"
  },
  "dependencies": {
    "ky": "^2.0.2",
    "zod": "^4.4.1"
  }
}
