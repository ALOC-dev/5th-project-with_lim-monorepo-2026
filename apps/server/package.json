{
  "name": "@monorepo/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --import tsx --watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --sourcemap --external:express",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --env-file-if-exists=.env --import tsx src/scripts/recommendation-engine/test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@monorepo/api-contracts": "workspace:*",
    "@monorepo/recommendation-engine": "workspace:*",
    "cors": "^2.8.6",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.17",
    "esbuild": "^0.27.7",
    "tsx": "^4.19.3"
  }
}
